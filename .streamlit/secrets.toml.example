# Secrets de EXEMPLO — no Streamlit Cloud cole isto em Settings → Secrets
# NÃO commitar secrets reais.

# --- MODO TESTE RÁPIDO (sem Google) ---
# Use isto primeiro para validar a app no Cloud.
[app]
dev_bypass = true
allowed_emails = ["ivanzimmbarros@gmail.com"]

# --- MODO PRODUÇÃO FAMILIAR (depois) ---
# Desligue dev_bypass e preencha o bloco [auth] Google.
# [app]
# dev_bypass = false
# allowed_emails = ["email1@gmail.com", "email2@gmail.com"]
#
# [auth]
# redirect_uri = "https://<NOME-DO-APP>.streamlit.app/oauth2callback"
# cookie_secret = "gerar-um-segredo-forte"
# client_id = "GOOGLE_CLIENT_ID"
# client_secret = "GOOGLE_CLIENT_SECRET"
# server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"
